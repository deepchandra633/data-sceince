class Emp:
    comp="HP"
    def __init__(self,name,sal):
        self.name=name
        self.sal=sal
        
    def printDetails(self):
        print(f"The Company of {self.name} is {self.comp} with salary ${self.sal}")
e=Emp("Deepchandra",1200)
e.printDetails()


class Emp:
    comp="HP"
    def __init__(self,name,sal):
        self.name=name
        self.sal=sal
        
    def printDetails(self):
        print(f"The Company of {self.name} is {self.comp} with salary ${self.sal}")

    @staticmethod
    def printTime():
        print(f"the time is now")
e=Emp("Deepchandra",1200)
e.printDetails()
e.printTime()



